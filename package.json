{
  "name": "mnemosyne-engine",
  "version": "0.1.0",
  "description": "A graph-governed, voice-first, sleep-augmented learning operating system.",
  "license": "MIT",
  "type": "module",
  "private": false,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @mnemosyne/web",
    "api:dev": "npm run start -w @mnemosyne/api",
    "api:migrate": "npm run migrate -w @mnemosyne/api",
    "worker:start": "npm run start -w @mnemosyne/worker-service",
    "docker:config": "docker compose -f infra/docker/docker-compose.yml config",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up --build",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "build": "npm run build -w @mnemosyne/web",
    "preview": "npm run preview -w @mnemosyne/web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "npm audit --omit=optional --audit-level=moderate",
    "test": "vitest run",
    "verify": "npm run lint && npm run format:check && npm run typecheck && npm test && npm run build && npm run audit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.14.12",
    "@types/pg": "^8.20.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
