{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mnemosyne.engine/schema/concept.schema.json",
  "title": "ConceptNode",
  "type": "object",
  "required": [
    "id",
    "slug",
    "title",
    "domain",
    "concept_type",
    "difficulty",
    "importance",
    "status",
    "version"
  ],
  "properties": {
    "id": { "type": "string" },
    "slug": { "type": "string" },
    "title": { "type": "string" },
    "domain": { "type": "string" },
    "subdomain": { "type": "string" },
    "concept_type": {
      "enum": [
        "fact",
        "association",
        "definition",
        "procedure",
        "pattern",
        "model",
        "argument",
        "judgment",
        "motor_adjacent",
        "language_phrase",
        "system"
      ]
    },
    "claim_ids": { "type": "array", "items": { "type": "string" } },
    "difficulty": { "type": "number", "minimum": 0, "maximum": 1 },
    "importance": { "type": "number", "minimum": 0, "maximum": 1 },
    "abstraction_level": { "type": "number", "minimum": 0, "maximum": 1 },
    "volatility": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": { "enum": ["active", "experimental", "disputed", "deprecated", "archived"] },
    "version": { "type": "string" }
  }
}
