VITE_APP_NAME=Mnemosyne Engine
VITE_DEMO_USER_ID=user_demo
VITE_MNEMOSYNE_API_URL=http://127.0.0.1:8787
VITE_MNEMOSYNE_USER_ID=user_demo
DATABASE_URL=postgres://mnemosyne:mnemosyne@localhost:5432/mnemosyne
HOST=0.0.0.0
PORT=8787
MNEMOSYNE_ENV=local
MNEMOSYNE_STORAGE=postgres
MNEMOSYNE_RUN_MIGRATIONS=false
MNEMOSYNE_SEED_DEMO=false
MNEMOSYNE_MIGRATIONS_DIR=infra/migrations
MNEMOSYNE_OBJECT_STORAGE_ROOT=.mnemosyne/objects
MNEMOSYNE_WORKER_MODE=loop
MNEMOSYNE_WORKER_QUEUES=scheduler,audio_render
MNEMOSYNE_WORKER_MAX_JOBS=10
MNEMOSYNE_WORKER_POLL_MS=1000
MNEMOSYNE_AUDIO_OUTPUT_FORMAT=m4a
